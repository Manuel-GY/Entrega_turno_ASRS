FROM php:8.2-apache

# Habilitar mod_rewrite para el .htaccess
RUN a2enmod rewrite

# Instalar extensiones necesarias (SQLite3 viene nativo, pero aseguramos dependencias de desarrollo comunes)
RUN apt-get update && apt-get install -y \
    libsqlite3-dev \
    && docker-php-ext-install pdo_mysql

# Configurar directorio de trabajo
WORKDIR /var/www/html

# Copiar archivos de la web (se configurará volumen de base de datos)
COPY . /var/www/html/

# Asegurar permisos correctos para que Apache escriba en SQLite
RUN mkdir -p /var/www/html/db_data && chown -R www-data:www-data /var/www/html

EXPOSE 80
